{
  "manifest_version": 3,
  "name": "AI Credit Helper",
  "version": "1.0",
  "description": "Opens the best AI IDE account based on cooldown timers.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3002/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Credit Helper"
  }
}
